{
  "name": "box-backend",
  "version": "1.0.0",
  "description": "Fastify best-practice starter",
  "private": true,
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch --include './src/*' ./src/server.ts",
    "swagger:generate": "tsx ./scripts/generate-swagger.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "oxlint . --node-plugin --vitest-plugin --ignore-pattern dist --ignore-pattern node_modules --ignore-pattern coverage",
    "test": "vitest run"
  },
  "keywords": [
    "fastify",
    "typescript",
    "api"
  ],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.32.1",
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/sensible": "^6.0.4",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@fastify/type-provider-typebox": "^6.1.0",
    "@sinclair/typebox": "^0.34.48",
    "@supabase/supabase-js": "^2.100.0",
    "env-schema": "^7.0.0",
    "fastify": "^5.8.2",
    "fastify-plugin": "^5.1.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "oxlint": "^1.56.0",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
