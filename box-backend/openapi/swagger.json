    "/": {
      "get": {
        "tags": [
          "system"
        ],
        "responses": {
          "200": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "name",
                    "version",
                    "environment"
                  ],
                  "properties": {
                    "name": {
                      "type": "string"
                    },
                    "version": {
                      "type": "string"
                    },
                    "environment": {
                      "anyOf": [
                        {
                          "type": "string",
                          "enum": [
                            "development"
                          ]
                        },
                        {
                          "type": "string",
                          "enum": [
                            "test"
                          ]
                        },
                        {
                          "type": "string",
                          "enum": [
                            "production"
                          ]
                        }
                      ]
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
